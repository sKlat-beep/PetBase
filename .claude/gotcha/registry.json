      "gotcha_id": "gotcha-cd-and-git-chain",
      "name": "cd + git chained with && or ;",
      "description": "Chaining `cd <path> && git <cmd>` fails because shell state (current directory) does not persist between Bash tool calls. The git command may run in the wrong directory or fail silently.",
      "root_cause": "Bash tool calls are independent subshells. `cd` changes only the subprocess's directory, not the next call. See feedback_git_commands.md.",
      "recommended_fix": "Use `git -C /absolute/path <cmd>` instead of `cd /path && git <cmd>`.",
      "signature": {
        "patterns": [],
        "regex_patterns": [
          "cd .+&&.+git",
          "cd .+;.+git"
        ]
      },
      "semantic_representation": {
        "action": "cd_then_git",
        "risk": "wrong working directory for git"
      },
      "preventative_rule": {
        "rule_type": "advisory",
        "condition": "cd combined with git via && or ;",
        "action": "suggest_modified_command",
        "severity": "medium",
        "applies_to_command_families": [],
        "applies_to_environments": ["development"],
        "suggested_command": "git -C /absolute/path <subcommand>",
        "requires_confirmation": false,
        "override_allowed": true,
        "last_validated_at": "2026-03-21T00:00:00Z"
      },
      "examples": [
        "cd app && git status",
        "cd C:/Admin/Projects/PetBase; git log"
      ],
      "context_tags": ["git", "shell", "compound-command"],
      "confidence_profile": {
