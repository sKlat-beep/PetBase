      "gotcha_id": "gotcha-deploy-before-build-validated",
      "name": "Firebase deploy before build validated",
      "description": "Running `firebase deploy` before both app/ and functions/ builds pass causes runtime errors requiring rollback. The delivery gate in WORKFLOW.md §2 mandates test-validator passage first.",
      "root_cause": "Skipped delivery gate — test-validator (npm run build in app/ and functions/) must exit 0 before any deploy.",
      "recommended_fix": "Run `npm --prefix app run build && npm --prefix functions run build` first. Both must exit 0. Then confirm task status is `review` in TODO.md before deploying.",
      "signature": {
        "patterns": ["firebase deploy"],
        "regex_patterns": []
      },
      "semantic_representation": {
        "action": "deploy",
        "target": "firebase",
        "risk": "skipping build validation"
      },
      "preventative_rule": {
        "rule_type": "advisory",
        "condition": "firebase deploy",
        "action": "warn",
        "severity": "high",
        "applies_to_command_families": ["firebase"],
        "applies_to_environments": ["development", "production"],
        "suggested_command": "npm --prefix app run build && npm --prefix functions run build",
        "requires_confirmation": false,
        "override_allowed": true,
        "last_validated_at": "2026-03-21T00:00:00Z"
      },
      "examples": [
        "firebase deploy --only hosting",
        "firebase deploy --only functions",
        "firebase deploy"
      ],
      "context_tags": ["firebase", "deploy", "build"],
      "confidence_profile": {
