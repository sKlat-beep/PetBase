      "gotcha_id": "gotcha-git-push-without-approval",
      "name": "git push without explicit user approval",
      "description": "Running `git push` without first asking for user approval violates SYSTEM_RULES §6 and agents/claude-code.md. Pushing unreviewed commits or to the wrong remote can cause unrecoverable state.",
      "root_cause": "SYSTEM_RULES §6: 'No git push without asking for approval.' Source control rule — explicit system constraint.",
      "recommended_fix": "Ask the user: 'Ready to push to origin/main. Shall I run git push? [yes/no]' — wait for explicit confirmation before executing.",
      "signature": {
        "patterns": ["git push"],
        "regex_patterns": ["^git push( |$)"]
      },
      "semantic_representation": {
        "action": "git_push",
        "risk": "publishing unreviewed commits to remote"
      },
