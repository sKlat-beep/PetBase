      "gotcha_id": "gotcha-npm-command-missing-prefix",
      "name": "npm run without --prefix in multi-workspace repo",
      "description": "Running bare `npm run <script>` from repo root fails — the root has no package.json scripts. Must use `npm --prefix app` or `npm --prefix functions` to target the correct workspace.",
      "root_cause": "PetBase is a monorepo. The repo root has no scripts section. `npm run build` at root exits non-zero with 'missing script' or runs the wrong package.",
      "recommended_fix": "Use `npm --prefix app run build` or `npm --prefix functions run build`. Never bare `npm run *` from repo root.",
      "signature": {
        "patterns": ["npm run "],
