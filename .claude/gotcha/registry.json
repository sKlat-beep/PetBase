    {
      "gotcha_id": "gotcha-git-force-push",
      "name": "git force push — destructive remote history rewrite",
      "description": "`git push --force` or `git push -f` rewrites remote history and can permanently destroy commits on the upstream branch. Especially catastrophic on main. SYSTEM_RULES prohibits destructive git ops without explicit confirmation.",
      "root_cause": "Destructive operation — no recovery path if remote had commits not in local history. SYSTEM_RULES §6 prohibits without confirmation.",
      "recommended_fix": "Use `git push --force-with-lease` (safer — fails if remote has new commits) and always confirm with user first. On main/master: do not force push.",
      "signature": {
        "patterns": ["git push --force", "git push -f "],
        "regex_patterns": ["git push.*(--force|-f)\\b"]
      },
      "semantic_representation": {
        "action": "git_force_push",
        "risk": "destructive remote history rewrite"
      },
      "preventative_rule": {
        "rule_type": "advisory",
        "condition": "git push with --force or -f flag",
        "action": "warn",
        "severity": "critical",
        "applies_to_command_families": [],
        "applies_to_environments": ["development", "production"],
        "suggested_command": "git push --force-with-lease",
        "requires_confirmation": true,
        "override_allowed": true,
        "last_validated_at": "2026-03-21T00:00:00Z"
      },
      "examples": [
        "git push --force",
        "git push -f",
        "git push origin main --force",
        "git push -f origin main"
      ],
      "context_tags": ["git", "push", "destructive", "force"],
